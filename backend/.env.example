# Django
DJANGO_SECRET_KEY=your-secret-key-here-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (descomenta para usar con docker-compose o producción)
# DATABASE_URL=postgres://finanzas_user:your-db-password@localhost:5432/finanzas_db
DB_NAME=finanzas_db
DB_USER=finanzas_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Encriptación AES-256 (32 bytes en base64)
# Generar con: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_KEY=

# Meta / WhatsApp Business API
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=

# Gemini API
GEMINI_API_KEY=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,capacitor://localhost,http://localhost
